<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- Default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Security headers (set at server level — required for frame-ancestors, HSTS, etc.
         since <meta> CSP tags cannot enforce these directives) -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=()" />
        <!-- Only add HSTS once HTTPS is confirmed working — enabling it prematurely on
             an HTTP-only site can lock users out until the max-age expires. -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' https://cdn.sheetjs.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';" />
      </customHeaders>
    </httpProtocol>

    <!-- Remove IIS version fingerprinting, deny directory browsing -->
    <security>
      <requestFiltering removeServerHeader="true">
        <fileExtensions>
          <add fileExtension=".md" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <directoryBrowse enabled="false" />

    <!-- Correct MIME type for .xlsx (IIS sometimes lacks this by default) -->
    <staticContent>
      <remove fileExtension=".xlsx" />
      <mimeMap fileExtension=".xlsx" mimeType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
    </staticContent>

  </system.webServer>
</configuration>
